generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  name      String
  userName  String      @unique
  email     String      @unique
  password  String
  birthDate DateTime
  avatarUrl String?
  coverUrl  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  posts     Post[]
  comments  Comment[]
  topics    UserTopic[]
}

model Post {
  id        String    @id @default(uuid())
  content   String
  ups       Int       @default(0)
  downs     Int       @default(0)
  mediaUrl  String?
  userId    String?
  edited    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  User      User?     @relation(fields: [userId], references: [id])
  comments  Comment[]
}

model Topic {
  id        String      @id @default(uuid())
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  users     UserTopic[]
}

model UserTopic {
  id      String @id @default(uuid())
  userId  String
  topicId String
  User    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  Topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  ups       Int      @default(0)
  downs     Int      @default(0)
  postId    String
  userId    String
  edited    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Post      Post?    @relation(fields: [postId], references: [id])
  User      User?    @relation(fields: [userId], references: [id])
}
